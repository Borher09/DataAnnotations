@model AtvDataAnnotations.Models.ClientePremiumViewModel

@{
    ViewData["Title"] = "Cadastro de Cliente Premium";
}

<div class="container mt-5">
    <h2>@ViewData["Title"]</h2>
    <hr />

    <form asp-action="Cadastrar" method="post">
        <div class="row">
            <div class="form-group col-md-12 mb-3">
                <label asp-for="NomeCompleto" class="control-label"></label>
                <input asp-for="NomeCompleto" class="form-control" placeholder="Digite seu nome completo" />
                <span asp-validation-for="NomeCompleto" class="text-danger"></span>
            </div>

            <div class="form-group col-md-6 mb-3">
                <label asp-for="DataNascimento" class="control-label"></label>
                <input asp-for="DataNascimento" class="form-control" />
                <span asp-validation-for="DataNascimento" class="text-danger"></span>
            </div>

            <div class="form-group col-md-6 mb-3">
                <label asp-for="Cpf" class="control-label"></label>
                <input asp-for="Cpf" class="form-control" placeholder="000.000.000-00" />
                <span asp-validation-for="Cpf" class="text-danger"></span>
            </div>

            <div class="form-group col-md-6 mb-3">
                <label asp-for="TelefoneCelular" class="control-label"></label>
                <input asp-for="TelefoneCelular" class="form-control" placeholder="(00) 00000-0000" />
                <span asp-validation-for="TelefoneCelular" class="text-danger"></span>
            </div>

            <div class="form-group col-md-6 mb-3">
                <label asp-for="UrlPerfilLinkedIn" class="control-label"></label>
                <input asp-for="UrlPerfilLinkedIn" class="form-control" placeholder="https://linkedin.com/in/seu-perfil" />
                <span asp-validation-for="UrlPerfilLinkedIn" class="text-danger"></span>
            </div>

            <div class="form-group col-md-6 mb-3">
                <label asp-for="RendaMensal" class="control-label"></label>
                <input asp-for="RendaMensal" class="form-control" />
                <span asp-validation-for="RendaMensal" class="text-danger"></span>
            </div>

            <div class="form-group col-md-6 mb-3">
                <label asp-for="NumeroCartaoCredito" class="control-label"></label>
                <input asp-for="NumeroCartaoCredito" class="form-control" />
                <span asp-validation-for="NumeroCartaoCredito" class="text-danger"></span>
            </div>

            <div class="form-group col-md-6 mb-3">
                <label asp-for="SenhaAcesso" class="control-label"></label>
                <input asp-for="SenhaAcesso" type="password" class="form-control" />
                <span asp-validation-for="SenhaAcesso" class="text-danger"></span>
            </div>

            <div class="form-group col-md-6 mb-3">
                <label asp-for="ConfirmarSenhaAcesso" class="control-label"></label>
                <input asp-for="ConfirmarSenhaAcesso" type="password" class="form-control" />
                <span asp-validation-for="ConfirmarSenhaAcesso" class="text-danger"></span>
            </div>
        </div>

        <div class="form-group mt-3">
            <button type="submit" class="btn btn-primary">Cadastrar Cliente Premium</button>
        </div>
    </form>
</div>
